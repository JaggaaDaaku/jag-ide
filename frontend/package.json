{
  "name": "jag-ide",
  "version": "0.1.0",
  "description": "Jag IDE — Agent-first autonomous development platform",
  "main": "dist/main.js",
  "scripts": {
    "start": "electron .",
    "build": "tsc -p tsconfig.main.json && webpack --config webpack.config.js --mode production",
    "build:dev": "tsc -p tsconfig.main.json && webpack --config webpack.config.js --mode development",
    "dev": "concurrently \"webpack --config webpack.config.js --mode development --watch\" \"electron .\"",
    "test": "jest"
  },
  "dependencies": {
    "electron": "^28.0.0",
    "monaco-editor": "^0.45.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.3.7",
    "concurrently": "^8.2.2",
    "css-loader": "^6.11.0",
    "electron-builder": "^24.9.0",
    "jest": "^29.7.0",
    "style-loader": "^3.3.4",
    "ts-loader": "^9.5.7",
    "typescript": "^5.3.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "build": {
    "appId": "com.jag.ide",
    "productName": "Jag IDE",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    }
  }
}
